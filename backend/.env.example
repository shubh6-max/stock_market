# Azure OpenAI
AZURE_ENDPOINT=
AZURE_DEPLOYMENT=
AZURE_API_KEY=
AZURE_API_VERSION=2024-02-15-preview

# Market data mode
# Use offline while Yahoo is rate-limited. Kite routes are available separately under /api/kite/*.
MARKET_DATA_MODE=offline
MARKET_DATA_PROVIDER=kite

# Frontend app URL used after Kite login completes.
# Local Vite default:
FRONTEND_URL=http://localhost:5173

# Kite Connect
# Keep actual values only in backend/.env. Never commit backend/.env.
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=https://precompliant-lexi-unspacious.ngrok-free.dev/api/kite/callback
